generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String         @id
  email              String         @unique
  createdAt          DateTime       @default(now())
  onboardingComplete Boolean        @default(false)
  voiceProfile       String?
  plan               String         @default("FREE")
  subscriptionDate   DateTime?
  creditsUsed        Int            @default(0)
  creditsLimit       Int            @default(10)
  bonusPosts         Int            @default(0)
  referralCode       String         @unique @default(uuid())
  referralCount      Int            @default(0)
  referredBy         String?
  linkedinAccessToken String?
  linkedinProfileId   String?
  linkedinName        String?
  linkedinConnectedAt DateTime?
  linkedinTokenExpiry DateTime?
  hookAnalyses       HookAnalysis[]
  posts              Post[]
}

model Post {
  id        String   @id @default(uuid())
  content   String
  tone      String?
  type      String?
  userId    String
  createdAt DateTime @default(now())
  hookScore Int?
  provider  String?  @default("groq-llama3-70b")
  publishedToLinkedIn   Boolean   @default(false)
  linkedinPostId        String?
  publishedAt           DateTime?
  user      User     @relation(fields: [userId], references: [id])
}

model HookAnalysis {
  id        String   @id @default(uuid())
  hookText  String
  score     Int
  feedback  String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model MarketingSettings {
  id                 String   @id @default(uuid())
  productName        String
  productDescription String
  targetAudience     String
  brandVoice         String
  primaryWebsiteUrl  String
  enabledPlatforms   String   @default("[\"linkedin\", \"twitter\"]")
  postsPerDay        Int      @default(3)
  automationConfig   String?
  timeZone           String   @default("UTC")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MarketingPost {
  id           String           @id @default(uuid())
  platform     String
  content      String
  status       String           @default("draft")
  remoteStatus String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  errorMessage String?
  utmCampaign  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  clicks       MarketingClick[]
}

model MarketingClick {
  id        String        @id @default(uuid())
  postId    String
  clickedAt DateTime      @default(now())
  sourceIp  String?
  post      MarketingPost @relation(fields: [postId], references: [id])
}

model MarketingArticle {
  id        String    @id @default(uuid())
  title     String
  slug      String    @unique
  platform  String
  content   String
  status    String    @default("draft")
  targetUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  postedAt  DateTime?
}

model AdminUser {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id           String    @id @default(uuid())
  sessionToken String    @unique
  expiresAt    DateTime
  adminUserId  String
  createdAt    DateTime  @default(now())
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
}

model Lead {
  id        String          @id @default(uuid())
  userId    String?
  email     String          @unique
  name      String?
  source    String
  status    String
  tags      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    OutreachEvent[]
}

model OutreachSequence {
  id          String          @id @default(uuid())
  name        String
  triggerType String
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  events      OutreachEvent[]
  steps       OutreachStep[]
}

model OutreachStep {
  id               String           @id @default(uuid())
  sequenceId       String
  stepNumber       Int
  delayMinutes     Int
  subjectTemplate  String
  bodyTemplateHtml String
  bodyTemplateText String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  events           OutreachEvent[]
  sequence         OutreachSequence @relation(fields: [sequenceId], references: [id])
}

model OutreachEvent {
  id            String           @id @default(uuid())
  leadId        String
  sequenceId    String
  stepId        String
  eventType     String
  plannedSendAt DateTime
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime         @default(now())
  lead          Lead             @relation(fields: [leadId], references: [id])
  sequence      OutreachSequence @relation(fields: [sequenceId], references: [id])
  step          OutreachStep     @relation(fields: [stepId], references: [id])
}

model SupportTicket {
  id         String               @id @default(uuid())
  userId     String?
  email      String
  subject    String
  message    String
  status     String               @default("open")
  priority   String               @default("normal")
  resolvedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  events     SupportTicketEvent[]
}

model SupportTicketEvent {
  id        String        @id @default(uuid())
  ticketId  String
  eventType String
  actor     String
  message   String?
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
}

model SupportFAQ {
  id             String   @id @default(uuid())
  question       String
  answerMarkdown String
  category       String
  tags           String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SupportArticle {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  contentMarkdown String
  category        String
  tags            String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Referral {
  id         String   @id @default(uuid())
  referrerId String
  referredId String   @unique
  createdAt  DateTime @default(now())
}
